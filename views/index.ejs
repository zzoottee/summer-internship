    <main>
        <h1 class="visually-hidden">TL:TECH</h1>

        <div class="pin-spacer"
            style="order: 0; place-self: auto; grid-area: auto; z-index: auto; float: none; flex-shrink: 1; display: flex; margin: 0px; inset: 0px; position: relative; flex-basis: auto; overflow: visible; box-sizing: border-box; width: 1905px; height: 884px; padding: 0px;">
            <section class="section hero" id="hero"
                style="translate: none; rotate: none; scale: none; left: 0px; top: 0.001px; margin: 0px; max-width: 1905px; width: 1905px; max-height: 884px; height: 884px; padding: 303px 230px 260px; box-sizing: border-box; position: fixed; transform: translate(0px, 0px);">
                <video class="hero__video video-src" autoplay="" loop="" muted="" playsinline="" width="1920"
                    height="1080" preload="auto" src="/upload/iblock/2c4/cujadwxyw3ysu98gpunkak7v02xiq1ue.mp4"
                    data-src="/upload/iblock/2c4/cujadwxyw3ysu98gpunkak7v02xiq1ue.mp4"></video>

                <h2 class="hero__title heading heading--type-h1">
                    <%- db.heroTitle %>
                </h2>
            </section>

        </div>
        <section class="section section--rounded-left section--over advantages">
            <div class="section__anchor" id="advantages"></div>

            <div class="advantages__container container">
                <div>
                    <p class="advantages__title">
                        <% db.advantages.forEach(function(item) { %>
                            <span class="advantages__title-part <%= item.titleImage ? 'advantages__title-part--icon' : '' %>">
                                <% if (item.titleImage) { %>
                                    <img src="<%= item.titleImage %>" alt="tl-logo" width="80" height="80">
                                <% } %>
                                <% if (item.titleText) { %>
                                    <%= item.titleText %>
                                <% } %>
                            </span>
                        <% }); %>
                    </p>
                </div>

                <ul class="advantages__list" style="opacity: 0.0419; visibility: inherit;">
                    <% db.advantages.forEach(function(item) { %>
                        <li class="advantages__item">
                            <span class="advantages__item-title">
                                <% if (item.titleImage) { %>
                                    <img src="<%= item.titleImage %>" alt="tl-logo" width="80" height="80">
                                <% } %>
                                <% if (item.titleText) { %>
                                    <!-- Добавим небольшой отступ, если картинка и текст идут вместе -->
                                    <span style="<%= item.titleImage ? 'display: block; margin-top: 5px;' : '' %>">
                                        <%= item.titleText %>
                                    </span>
                                <% } %>
                            </span>
                            <%- item.description %>
                        </li>
                    <% }); %>
                </ul>
            </div>
        </section>

