        <section class="section section--full-height section--rounded-right section--over directions" id="directions">
            <div class="directions__container container">
                <h2 class="directions__title heading heading--type-section">
                    Направления </h2>

                <div class="directions__list">
                    <% db.directions.forEach(function(dir) { %>
                    <article class="directions__item accordion">
                        <div class="accordion__title">
                            <span><%= dir.name %></span>

                            <div class="accordion__title-stak-list bages-list">
                                <% dir.technologies.forEach(function(tech) { %>
                                <div class="bages-list__item">
                                    <img src="<%= tech.techImage %>" alt="<%= tech.techName %>">
                                    <%= tech.techName %>
                                </div>
                                <% }); %>
                            </div>

                            <div class="accordion__toggle">
                                <svg width="24" height="14" viewBox="0 0 24 14" fill="none"
                                    xmlns="http://www.w3.org/2000/svg">
                                    <circle cx="2" cy="2" r="2" fill="#507BCE"></circle>
                                    <circle cx="7" cy="7" r="2" fill="#507BCE"></circle>
                                    <circle cx="12" cy="12" r="2" fill="#507BCE"></circle>
                                    <circle cx="17" cy="7" r="2" fill="#507BCE"></circle>
                                    <circle cx="22" cy="2" r="2" fill="#507BCE"></circle>
                                </svg>
                            </div>
                        </div>

                        <div class="accordion__body">
                            <div class="accordion__content ustyle">
                                <%- dir.content %>
                            </div>
                        </div>
                    </article>
                    <% }); %>
                </div>
            </div>
        </section>

